# EmailJS Configuration
# Copy this file to .env and fill in your values from https://www.emailjs.com/
# Then add these same variables to Vercel Dashboard → Project Settings → Environment Variables

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
